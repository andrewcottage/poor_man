<div class="w-full">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <section class="mt-6 overflow-hidden rounded-[2rem] bg-slate-900 px-6 py-10 text-white sm:px-10 lg:px-12">
      <div class="grid gap-8 lg:grid-cols-[1.3fr_0.7fr] lg:items-end">
        <div>
          <p class="text-sm uppercase tracking-[0.25em] text-amber-300"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %></p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">A clearer free tier now, paid planning and grocery power next.</h1>
          <p class="mt-4 max-w-2xl text-base text-slate-200 sm:text-lg"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> is the paid layer for AI recipe generation, collections, meal planning, grocery automation, and other high-cost features. Free stays generous. Pro keeps the expensive workflows sustainable.</p>

          <% if Current.user&.pro? %>
            <p class="mt-6 inline-flex rounded-full bg-white/10 px-4 py-2 text-sm font-medium text-white">
              Your <%= Current.user.plan_label %> plan is active<% if Current.user.plan_expires_at.present? %> through <%= l(Current.user.plan_expires_at.to_date, format: :long) %><% end %>.
            </p>
          <% end %>
        </div>

        <div class="rounded-[1.5rem] bg-white/10 p-6 backdrop-blur">
          <p class="text-sm uppercase tracking-[0.2em] text-slate-300">Today</p>
          <ul class="mt-4 space-y-3 text-sm text-slate-100">
            <li>Free includes 50 favorites, 5 recipe submissions, 1 collection, and 1 AI trial.</li>
            <li><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> unlocks unlimited collections and submissions plus 15 AI generations per month.</li>
            <li>Meal planning, grocery lists, nutrition estimates, and advanced recipe tools are live in Pro.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mt-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Free</p>
        <h2 class="mt-3 text-3xl font-semibold text-gray-900">$0</h2>
        <p class="mt-3 text-sm text-gray-600">Browse, rate, favorite, and submit recipes with sensible starter limits.</p>
        <ul class="mt-6 space-y-3 text-sm text-gray-700">
          <li>50 favorites</li>
          <li>5 recipe submissions</li>
          <li>1 cookbook collection</li>
          <li>1 free AI recipe generation trial</li>
        </ul>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <% @plan_options.each do |plan| %>
          <article class="rounded-[2rem] border border-gray-900 bg-gray-950 p-6 text-white shadow-sm">
            <p class="text-sm uppercase tracking-[0.2em] text-amber-300"><%= plan[:name] %></p>
            <div class="mt-4 flex items-end gap-2">
              <h2 class="text-4xl font-semibold"><%= plan[:price] %></h2>
              <p class="pb-1 text-sm text-gray-300"><%= plan[:cadence] %></p>
            </div>
            <ul class="mt-6 space-y-3 text-sm text-gray-200">
              <li>Unlimited favorites</li>
              <li>Unlimited recipe submissions</li>
              <li>Unlimited collections and cookbooks</li>
              <li>15 AI recipe generations each month</li>
            </ul>

            <div class="mt-8">
              <% if Current.user.blank? %>
                <%= link_to "Create an account", new_registration_path, class: "inline-flex w-full justify-center rounded-xl bg-white px-4 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100" %>
              <% elsif Current.user.plan == plan[:id] %>
                <div class="rounded-xl bg-white/10 px-4 py-3 text-center text-sm font-medium text-white">Current plan</div>
              <% elsif @billing_enabled %>
                <%= button_to "Subscribe with Stripe", billing_checkout_sessions_path(plan: plan[:id]), method: :post, class: "inline-flex w-full justify-center rounded-xl bg-white px-4 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-100" %>
              <% else %>
                <p class="rounded-xl bg-white/10 px-4 py-3 text-center text-sm text-gray-200">Checkout is not configured yet. Join the waitlist below.</p>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="mt-10 rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-gray-500">AI Credits</p>
          <h2 class="mt-2 text-2xl font-semibold text-gray-900">Buy extra generations without upgrading</h2>
          <p class="mt-2 text-sm text-gray-600">Credit packs are useful when you are bulk-creating recipes or need regeneration passes beyond your plan allowance.</p>
        </div>
      </div>

      <div class="mt-6">
        <%= render "recipes/generations/credit_packs", credit_packs: @credit_packs %>
      </div>
    </section>

    <section class="mt-10 overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-sm">
      <div class="border-b border-gray-200 px-6 py-5 sm:px-8">
        <h2 class="text-2xl font-semibold text-gray-900">Free vs <%= Billing::PlanCatalog::PRO_DISPLAY_NAME %></h2>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Feature</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Free</th>
              <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @feature_rows.each do |feature, free_value, pro_value| %>
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= feature %></td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= free_value %></td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= pro_value %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="my-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-[2rem] border border-amber-200 bg-amber-50 p-6">
        <p class="text-sm uppercase tracking-[0.2em] text-amber-700"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> today</p>
        <h2 class="mt-3 text-2xl font-semibold text-gray-900">Meal planning, grocery lists, nutrition, and advanced AI controls are included.</h2>
        <p class="mt-4 text-sm text-gray-700"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> now covers the full planning workflow: weekly meal planning, shared grocery lists, nutrition estimates, collections, and AI recipe generation with customization and regeneration controls.</p>
      </div>

      <div class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-gray-900">Join the <%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> waitlist</h2>
        <p class="mt-2 text-sm text-gray-600">Get launch updates even if checkout is not live yet.</p>

        <%= form_with model: @waitlist_entry, url: pro_waitlist_entries_path, class: "mt-6 space-y-4" do |form| %>
          <% if @waitlist_entry.errors.any? %>
            <div class="rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-700">
              <%= @waitlist_entry.errors.full_messages.to_sentence %>
            </div>
          <% end %>

          <div>
            <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
            <%= form.email_field :email, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
          </div>

          <div>
            <%= form.label :plan_preference, "Preferred plan", class: "block text-sm font-medium text-gray-700" %>
            <%= form.select :plan_preference, [["Monthly", "monthly"], ["Annual", "annual"]], { include_blank: "Either works" }, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
          </div>

          <%= form.hidden_field :source, value: "pricing_page" %>

          <%= form.submit "Join waitlist", class: "inline-flex w-full justify-center rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white hover:bg-gray-800" %>
        <% end %>
      </div>
    </section>
  </div>
</div>
