<%= form_with(model: recipe, data: { controller: "slug" }) do |form| %>
<% if recipe.errors.any? %>
<div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
  <h2><%= pluralize(recipe.errors.count, "error") %> prohibited this recipe from being saved:</h2>

  <ul>
    <% recipe.errors.each do |error| %>
    <li><%= error.full_message %></li>
    <% end %>
  </ul>
</div>
<% end %>

<div class="my-5">
  <%= form.label :title %>
  <%= form.text_field :title, 
      data: { 
        slug_target: "title",
        action: "input->slug#generateSlug"
      },
      class: "stovaro-input" %>
</div>

<% if defined?(@generation) && @generation&.data&.present? %>
  <!-- Images from AI Generation -->
  <div class="my-5">
    <h3 class="text-lg font-medium text-gray-900 mb-3">Generated Images</h3>
    <div class="stovaro-panel p-4">
      <% if @generation.image.attached? %>
        <div class="mb-4">
          <p class="text-sm font-medium text-gray-700 mb-2">Main Image:</p>
          <div class="relative inline-block">
            <%= image_tag @generation.image, class: "w-48 h-36 object-cover rounded border shadow-sm", alt: "Generated main image" %>
            <span class="absolute top-2 right-2 rounded bg-emerald-500 px-2 py-1 text-xs text-white">AI Generated</span>
          </div>
        </div>
      <% end %>
      
      <% if @generation.images.attached? %>
        <div>
          <p class="text-sm font-medium text-gray-700 mb-2">Gallery Images:</p>
          <div class="flex flex-wrap gap-3">
            <% @generation.images.each_with_index do |image, index| %>
              <div class="relative">
                <%= image_tag image, class: "w-32 h-24 object-cover rounded border shadow-sm", alt: "Generated gallery image #{index + 1}" %>
                <span class="absolute top-1 right-1 rounded bg-emerald-500 px-1.5 py-0.5 text-xs text-white">AI</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <% unless @generation.image.attached? || @generation.images.attached? %>
        <p class="text-sm text-slate-500">No images have been generated yet.</p>
      <% end %>
      
      <p class="mt-3 text-xs text-slate-600">
        These images will be automatically attached to your recipe when you save it.
      </p>
    </div>
    <%= form.hidden_field :generation_id, value: @generation.id %>
  </div>
<% else %>
  <!-- Regular image upload fields -->
  <div class="grid grid-cols-2 gap-4 my-5">
    <div>
      <%= form.label "Image*" %>
      <%= form.file_field :image, class: "stovaro-input" %>
    </div>

    <div>
      <%= form.label :extra_images %>
      <%= form.file_field :images, multiple: true, class: "stovaro-input" %>
    </div>
  </div>
<% end %>

<div class="my-5">
  <%= form.label :slug %>
  <%= form.text_field :slug, data: { slug_target: "slug" }, class: "mt-2 block w-full rounded-xl border border-stone-300 bg-stone-100 px-3 py-2 text-slate-600 shadow-sm" %>
</div>

<div class="my-5">
  <%= form.label :ingredient_list, "Ingredients" %>
  <%= form.text_area :ingredient_list,
      value: recipe.ingredient_list,
      rows: 8,
      placeholder: "2 cups flour\n1 tsp kosher salt\n3 tbsp olive oil, plus more for the pan",
      class: "stovaro-input" %>
  <p class="mt-2 text-xs text-slate-500">Enter one ingredient per line. We will parse quantity, unit, ingredient name, and notes into structured data.</p>
</div>

<div class="my-5">
  <%= form.label :instructions %>
  <%= form.rich_text_area :instructions, class: "stovaro-input" %>
</div>

<div class="my-5">
  <%= form.label :blurb %>
  <%= form.text_area :blurb, class: "stovaro-input" %>
</div>


<div class="my-5">
  <%= form.label :tags %>
  <%= form.text_field :tag_names, class: "stovaro-input" %>
</div>

<div class="my-5">
  <%= form.label :category %>
  <%= form.select :category_id, Category.all.map { |c| [c.title, c.id] }, { include_blank: "Select a category" }, class: "stovaro-select bg-white" %>
</div>

<div class="grid grid-cols-3 gap-4 my-5">
  <div>
    <%= form.label :cost %>
    <%= form.text_field :cost, class: "stovaro-input" %>
  </div>

  <div>
    <%= form.label :difficulty %>
    <%= form.select :difficulty, (1..5).to_a, { include_blank: "Select difficulty (1-5)", selected: recipe.difficulty }, class: "stovaro-select bg-white" %>
  </div>

  <div>
    <%= form.label :prep_time, "Prep Time (minutes)" %>
    <%= form.number_field :prep_time, class: "stovaro-input" %>
  </div>
</div>

<div class="my-5">
  <%= form.label :servings, "Servings" %>
  <%= form.number_field :servings, min: 1, class: "stovaro-input" %>
</div>

<div class="inline">
  <%= form.submit class: "stovaro-btn-primary cursor-pointer" %>
</div>
<% end %>
