<div class="mx-auto mt-8 pb-16 pt-6 sm:pb-24">
  <% selected_servings = @selected_servings || recipe.servings %>
  <% displayed_ingredients = @scaled_ingredients.presence || recipe.scaled_ingredients(selected_servings) %>

  <%= render 'shared/breadcrumbs', links: [
    { text: 'Recipies', url: recipes_path },
    { text: recipe.category.title, url: category_path(recipe.category.slug) },
    { text: recipe.title, url: recipe_path(recipe.slug) }
  ] %>

  <div class="mx-auto mt-8 max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="lg:grid lg:auto-rows-min lg:grid-cols-12 lg:gap-x-8">
      <div class="lg:col-span-5 lg:col-start-8">
        <div class="flex justify-between">
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h1 class="text-xl font-medium text-gray-900"><%= recipe.title %></h1>
              <% if Current.user&.admin? || recipe.author == Current.user %>
                <%= recipe_moderation_badge(recipe) %>
              <% end %>
            </div>
            <% if recipe.author.present? %>
              <p class="mt-2 text-sm text-gray-500">
                By <%= link_to recipe.author.username, cook_path(recipe.author.username), class: "font-semibold text-gray-700 underline" %>
              </p>
            <% end %>
          </div>

          <div class="flex justify-end">
            <%= link_to "Cook Mode", cook_recipe_path(recipe.slug, servings: selected_servings), class: "mr-4 rounded-full border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
            <%= link_to "Print", print_recipe_path(recipe.slug, servings: selected_servings), class: "mr-4 rounded-full border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
            <% if recipe.current_user_editable?  %>
            <%= link_to edit_recipe_path(recipe.slug), class: 'mr-4' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
            </svg>
            <% end %>
            <% end %>

            <% if recipe.current_user_rating %>
            <%= link_to edit_recipe_rating_path(recipe, recipe.current_user_rating), class: 'mr-4' do %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
              <path fill-rule="evenodd" d="M4.848 2.771A49.144 49.144 0 0 1 12 2.25c2.43 0 4.817.178 7.152.52 1.978.292 3.348 2.024 3.348 3.97v6.02c0 1.946-1.37 3.678-3.348 3.97a48.901 48.901 0 0 1-3.476.383.39.39 0 0 0-.297.17l-2.755 4.133a.75.75 0 0 1-1.248 0l-2.755-4.133a.39.39 0 0 0-.297-.17 48.9 48.9 0 0 1-3.476-.384c-1.978-.29-3.348-2.024-3.348-3.97V6.741c0-1.946 1.37-3.68 3.348-3.97ZM6.75 8.25a.75.75 0 0 1 .75-.75h9a.75.75 0 0 1 0 1.5h-9a.75.75 0 0 1-.75-.75Zm.75 2.25a.75.75 0 0 0 0 1.5H12a.75.75 0 0 0 0-1.5H7.5Z" clip-rule="evenodd" />
            </svg>

            <% end %>
            <% else %>
            <%= link_to new_recipe_rating_path(recipe), class: 'mr-4' do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
            <% end %>

            <% end %>
            <% if recipe.current_user_favorite %>
            <%= button_to recipe_favorite_path(recipe, recipe.current_user_favorite), method: :delete, class: 'mr-4' do  %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
            </svg>
            <% end %>
            <% else %>
            <%= button_to recipe_favorites_path(recipe), method: :post, class: 'mr-4' do  %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
            </svg>
            <% end %>
            <% end %>
            <div data-controller="clipboard">
              <%= link_to recipe_path(recipe.slug), class: 'copy-link mr-4', "data-clipboard-target" => "link", "data-action" => "click->clipboard#share" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
              </svg>
              <% end %>
            </div>
          </div>
        </div>
        <div class="flex mt-2 sm:mt-1">
          <div class="flex justify-between w-full gap-x-4">
            <%= render 'recipes/recipe/cost', recipe: recipe %>
            <%= render 'recipes/recipe/difficulty', difficulty: recipe.difficulty %>
            <%= render 'recipes/recipe/prep_time', recipe: recipe %>
          </div>
        </div>
        <%= render 'recipes/recipe/ratings', recipe: recipe %>

        <% if Current.user&.admin? || recipe.author == Current.user %>
        <div class="mt-4 rounded-2xl <%= recipe.rejected? ? 'bg-red-50 text-red-800' : recipe.pending? ? 'bg-yellow-50 text-yellow-800' : 'bg-green-50 text-green-800' %> p-4 text-sm">
          <% if recipe.rejected? %>
            <p class="font-semibold">This recipe was sent back for changes.</p>
            <% if recipe.rejection_reason.present? %>
              <p class="mt-2"><%= recipe.rejection_reason %></p>
            <% end %>
          <% elsif recipe.pending? %>
            <p class="font-semibold">This recipe is waiting for moderator approval.</p>
            <p class="mt-2">It stays private to you and admins until it is approved.</p>
          <% else %>
            <p class="font-semibold">This recipe is publicly visible.</p>
          <% end %>
        </div>
        <% end %>

      </div>

      <!-- Image gallery -->
      <div class="mt-8 lg:col-span-7 lg:col-start-1 lg:row-span-3 lg:row-start-1 lg:mt-0" data-controller="gallery">
        <h2 class="sr-only">Images</h2>

        <div class="relative">
          <!-- Main image display -->
          <div class="overflow-hidden rounded-lg">
            <%= image_tag(recipe.image, class: "w-full h-auto", data: { "gallery-target": "mainImage" }) if recipe.image.attached? %>
            <% recipe.images.each do |image| %>
            <%= image_tag(image, class: "w-full h-auto hidden", data: { "gallery-target": "mainImage" }) %>
            <% end %>
          </div>

          <% if recipe.images.any? %>
          <!-- Navigation buttons -->
          <button data-action="gallery#previous" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 rounded-full p-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75 3 12m0 0 3.75-3.75M3 12h18" />
            </svg>
          </button>
          <button data-action="gallery#next" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 rounded-full p-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
            </svg>
          </button>

          <!-- Thumbnail navigation -->
          <div class="flex gap-2 mt-4 overflow-x-auto">
            <% if recipe.image.attached? %>
            <%= image_tag(recipe.image, class: "w-20 h-20 object-cover rounded cursor-pointer", data: { "gallery-target": "thumbnail", action: "click->gallery#select", index: 0 }) %>
            <% end %>
            <% recipe.images.each_with_index do |image, index| %>
            <%= image_tag(image, class: "w-20 h-20 object-cover rounded cursor-pointer", data: { "gallery-target": "thumbnail", action: "click->gallery#select", index: index + 1 }) %>
            <% end %>
          </div>
          <% end %>
        </div>
      </div>

      <div class="mt4 lg:col-span-5">
        <% if displayed_ingredients.any? %>
        <div class="mt-8 border-t border-gray-200 pt-4">
          <div class="flex flex-wrap items-end justify-between gap-3">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">Ingredients</h2>
              <p class="mt-1 text-sm text-gray-500">
                <%= pluralize(selected_servings, "serving") %>
                <% if selected_servings != recipe.servings %>
                  from an original <%= pluralize(recipe.servings, "serving") %> recipe
                <% end %>
              </p>
            </div>
            <div class="flex gap-2">
              <% [ [selected_servings - 1, "-1"], [selected_servings + 1, "+1"] ].each do |target_servings, label| %>
                <% next if target_servings < 1 %>
                <%= link_to label, recipe_path(recipe.slug, servings: target_servings), class: "rounded-full border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
              <% end %>
            </div>
          </div>
          <ul class="mt-4 space-y-2 text-sm text-gray-700">
            <% displayed_ingredients.each do |ingredient| %>
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 rounded-full bg-gray-300"></span>
              <span><%= ingredient.display_text %></span>
            </li>
            <% end %>
          </ul>
        </div>
        <% end %>

        <div class="mt-8 rounded-3xl bg-gray-50 p-5">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Nutrition</p>
              <h2 class="mt-2 text-lg font-semibold text-gray-900">Estimated per serving</h2>
            </div>
            <% if recipe.nutrition_available? %>
              <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-200"><%= recipe.nutrition_coverage_label %></span>
            <% end %>
          </div>

          <% if Current.user&.pro? && recipe.nutrition_available? %>
            <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
              <div class="rounded-2xl bg-white px-4 py-4 text-center">
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Calories</p>
                <p class="mt-2 text-2xl font-semibold text-gray-900"><%= recipe.nutrition_calories %></p>
              </div>
              <div class="rounded-2xl bg-white px-4 py-4 text-center">
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Protein</p>
                <p class="mt-2 text-2xl font-semibold text-gray-900"><%= recipe.nutrition_protein_grams %>g</p>
              </div>
              <div class="rounded-2xl bg-white px-4 py-4 text-center">
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Carbs</p>
                <p class="mt-2 text-2xl font-semibold text-gray-900"><%= recipe.nutrition_carbs_grams %>g</p>
              </div>
              <div class="rounded-2xl bg-white px-4 py-4 text-center">
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500">Fat</p>
                <p class="mt-2 text-2xl font-semibold text-gray-900"><%= recipe.nutrition_fat_grams %>g</p>
              </div>
            </div>
          <% elsif recipe.nutrition_available? %>
            <p class="mt-4 text-sm text-gray-600"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> unlocks nutrition estimates and macro breakdowns. <%= link_to "See pricing", pricing_path, class: "font-semibold underline" %>.</p>
          <% else %>
            <p class="mt-4 text-sm text-gray-600">Nutrition estimates become available when the ingredient list can be matched reliably.</p>
          <% end %>
        </div>

        <div class="mt-8 border-t border-gray-200 pt-2">
          <h2 class="text-lg font-semibold text-gray-900">Instructions</h2>
          <% if selected_servings != recipe.servings %>
            <p class="mt-2 text-sm text-gray-500">Instruction text stays written for the original recipe; adjust ingredient amounts above for your target servings.</p>
          <% end %>
          <div class="prose prose-sm mt-4 text-gray-500">
            <%= recipe.instructions %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= render('recipes/recipe/reviews', ratings: recipe.ratings) if recipe.ratings.present? %>

  <div class="mx-auto mt-8 max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="mt-4">
      <p class="text-sm font-medium text-gray-700 mb-2">Tags:</p>
      <div class="flex flex-wrap gap-2">
        <%= link_to recipe.category.title, category_path(recipe.category.slug), class: "inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10" %>
        <% recipe.tags.first(7).each do |tag| %>
        <%= link_to tag.name, recipes_path(q: tag.name), class: "inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10" %>
        <% end %>
      </div>
    </div>

    <% if @related_recipes.present? %>
      <div class="mt-10">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Keep browsing</p>
            <h2 class="mt-2 text-2xl font-semibold text-gray-900">Related recipes</h2>
          </div>
          <%= link_to "More like this", recipes_path(q: recipe.category.title), class: "text-sm font-semibold text-emerald-700 hover:text-emerald-600" %>
        </div>

        <div class="mt-4 grid grid-cols-1 border-l border-gray-200 sm:grid-cols-2 lg:grid-cols-4">
          <% @related_recipes.each do |related_recipe| %>
            <%= render "recipes/card", recipe: related_recipe %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if Current.user %>
    <div class="mt-8 rounded-3xl bg-gray-50 p-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Collections</p>
          <h2 class="mt-2 text-xl font-semibold text-gray-900">Save this recipe into a cookbook</h2>
          <% saved_collections = Current.user.collections_for(recipe) %>
          <% if saved_collections.any? %>
            <div class="mt-3 flex flex-wrap gap-2">
              <% saved_collections.each do |collection| %>
                <span class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-medium text-gray-700 ring-1 ring-inset ring-gray-200"><%= collection.name %></span>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="w-full max-w-md">
          <% if @user_collections.present? %>
            <%= form_with url: profiles_collection_recipes_path, class: "space-y-3" do |form| %>
              <%= hidden_field_tag :recipe_id, recipe.id %>
              <%= select_tag :collection_id, options_from_collection_for_select(@user_collections, :id, :name), class: "block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
              <%= form.submit "Add to collection", class: "inline-flex justify-center rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white hover:bg-gray-800" %>
            <% end %>
          <% elsif Current.user.can_create_collection? %>
            <p class="text-sm text-gray-600">You have not created a collection yet.</p>
            <%= link_to "Create your first collection", profiles_collections_path, class: "mt-3 inline-flex rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white hover:bg-gray-800" %>
          <% else %>
            <p class="text-sm text-gray-600">Free accounts can create 1 collection.</p>
            <%= link_to "Upgrade to #{Billing::PlanCatalog::PRO_DISPLAY_NAME}", pricing_path, class: "mt-3 inline-flex rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white hover:bg-gray-800" %>
          <% end %>
        </div>
      </div>
    </div>
    <% end %>
  </div>
</div>
