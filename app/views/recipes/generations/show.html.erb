<div class="w-full" 
     data-controller="generation-status"
     data-generation-status-url-value="<%= recipes_generation_path(@generation) %>"
     data-generation-status-complete-value="<%= @generation.complete? %>">
  <% if notice.present? %>
  <p class="mb-5 inline-block rounded-2xl border border-emerald-200 bg-emerald-50 px-3 py-2 font-medium text-emerald-800" id="notice"><%= notice %></p>
  <% end %>

  <% content_for :title, "Recipe Generation: #{@generation.prompt}" %>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="overflow-hidden rounded-3xl border border-stone-200 bg-white shadow-sm">
      <div class="border-b border-stone-200 px-6 py-4">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h1 class="mb-2 text-2xl font-bold text-slate-900"><%= @generation.prompt %></h1>
            <p class="mb-4 text-sm text-slate-500">
              Generated <%= time_ago_in_words(@generation.created_at) %> ago
            </p>
            <div class="flex items-center space-x-4">
              <%= generation_status_badge(@generation) %>
              <div class="flex-1">
                <%= generation_progress_bar(@generation) %>
              </div>
            </div>
          </div>
          <div class="flex space-x-2">
            <%= link_to "Back to Generations", recipes_generations_path, class: "stovaro-btn-secondary px-3 py-2" %>
            <% if Current.user&.admin? || @generation.user == Current.user %>
            <%= link_to "Edit", edit_recipes_generation_path(@generation), class: "stovaro-btn-primary px-3 py-2" %>
            <%= button_to "Delete", recipes_generation_path(@generation), method: :delete, 
                data: { turbo_confirm: "Are you sure you want to delete this recipe generation? This cannot be undone." }, 
                class: "inline-flex items-center rounded-xl bg-red-600 px-3 py-2 text-sm font-medium leading-4 text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="px-6 py-6">
        <div class="mb-8 rounded-3xl bg-stone-100 p-5">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Generation controls</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <% {
                  "Diet" => @generation.dietary_preference.presence,
                  "Skill" => @generation.skill_level.presence,
                  "Servings" => @generation.servings.presence,
                  "Difficulty" => @generation.target_difficulty.presence
                }.each do |label, value| %>
                  <% next if value.blank? %>
                  <span class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 ring-1 ring-inset ring-stone-200"><%= "#{label}: #{value}" %></span>
                <% end %>
              </div>
              <% if @generation.avoid_ingredients.present? || @generation.ingredient_swaps.present? || @generation.customization_notes.present? %>
                <div class="mt-4 space-y-2 text-sm text-slate-600">
                  <% if @generation.avoid_ingredients.present? %>
                    <p><span class="font-semibold text-slate-900">Avoid:</span> <%= @generation.avoid_ingredients %></p>
                  <% end %>
                  <% if @generation.ingredient_swaps.present? %>
                    <p><span class="font-semibold text-slate-900">Preferred swaps:</span> <%= @generation.ingredient_swaps %></p>
                  <% end %>
                  <% if @generation.customization_notes.present? %>
                    <p><span class="font-semibold text-slate-900">Notes:</span> <%= @generation.customization_notes %></p>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="max-w-xs rounded-2xl bg-white px-4 py-4 text-sm text-slate-700 ring-1 ring-inset ring-stone-200">
              <p class="font-semibold text-slate-900"><%= generation_allowance_summary(Current.user) %></p>
            </div>
          </div>
        </div>

        <% if @generation.complete? %>
        <div class="mb-8">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-semibold text-slate-900">Generated Recipe</h2>
            <%= link_to "Create Recipe", new_recipe_path(generation_id: @generation.id), 
                class: "stovaro-btn-accent px-4 py-2" %>
          </div>
          <%= formatted_generation_data(@generation) %>
        </div>
        <% elsif @generation.data.present? %>
        <div class="mb-8">
          <h2 class="mb-4 text-xl font-semibold text-slate-900">Generated Recipe Data</h2>
          <%= formatted_generation_data(@generation) %>
          <div class="mt-4 rounded-2xl bg-amber-50 p-4">
            <p class="text-sm text-amber-800">
              <svg class="inline w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              Images are still being generated. Please check back in a few minutes.
            </p>
          </div>
        </div>
        <% else %>
        <div class="mb-8">
          <div class="text-center py-8">
            <div class="inline-flex items-center rounded-xl bg-stone-100 px-4 py-2 text-sm font-semibold leading-6 text-slate-700 shadow-sm">
              <svg class="-ml-1 mr-3 h-5 w-5 animate-spin text-emerald-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Generating recipe...
            </div>
            <p class="mt-2 text-sm text-slate-500">This may take a few minutes.</p>
          </div>
        </div>
        <% end %>

        <% if @generation.image.attached? %>
        <div class="mb-8">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-xl font-semibold text-slate-900">Main Image</h2>
            <%= button_to "Regenerate images", regenerate_images_recipes_generation_path(@generation), method: :post, class: "stovaro-btn-secondary px-4 py-2" %>
          </div>
          <div class="aspect-w-16 aspect-h-9 overflow-hidden rounded-lg bg-stone-100">
            <%= image_tag @generation.image, class: "w-full h-full object-cover", alt: "Generated recipe image" %>
          </div>
        </div>
        <% end %>

        <% if @generation.images.attached? %>
        <div class="mb-8">
          <h2 class="mb-4 text-xl font-semibold text-slate-900">Image Gallery</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% @generation.images.each do |image| %>
            <div class="aspect-w-4 aspect-h-3 overflow-hidden rounded-lg bg-stone-100">
              <%= image_tag image, class: "w-full h-full object-cover", alt: "Generated recipe image" %>
            </div>
            <% end %>
          </div>
        </div>
        <% end %>

        <% if @generation.data.present? %>
        <div class="mb-8">
          <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            <h2 class="text-xl font-semibold text-slate-900">Raw Data</h2>
            <div class="flex flex-wrap gap-3">
              <%= button_to "Regenerate recipe", regenerate_recipe_recipes_generation_path(@generation), method: :post, class: "stovaro-btn-secondary px-4 py-2" %>
              <%= button_to "Regenerate instructions", regenerate_instructions_recipes_generation_path(@generation), method: :post, class: "stovaro-btn-secondary px-4 py-2" %>
            </div>
          </div>
          <div class="rounded-lg bg-stone-100 p-4">
            <pre class="whitespace-pre-wrap text-sm text-slate-700"><%= JSON.pretty_generate(@generation.data) %></pre>
          </div>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div> 
