<div class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex justify-between items-start mb-4">
    <div class="flex-1">
      <h3 class="mb-2 text-lg font-semibold text-slate-900">
        <%= link_to generation.prompt, recipes_generation_path(generation), class: "hover:text-emerald-700" %>
      </h3>
      <p class="mb-3 text-sm text-slate-500">
        Generated <%= time_ago_in_words(generation.created_at) %> ago
      </p>
    </div>
    <div class="flex items-center space-x-2">
      <%= generation_status_badge(generation) %>
    </div>
  </div>

  <div class="mb-4">
    <p class="mb-2 text-sm text-slate-600">Progress:</p>
    <%= generation_progress_bar(generation) %>
  </div>

  <% if generation.data.present? %>
  <div class="mb-4">
    <% if generation.data['title'].present? %>
    <h4 class="text-md mb-1 font-medium text-slate-800"><%= generation.data['title'] %></h4>
    <% end %>
    <% if generation.data['blurb'].present? %>
    <p class="line-clamp-2 text-sm text-slate-600"><%= generation.data['blurb'] %></p>
    <% end %>
  </div>
  <% end %>

  <div class="flex justify-between items-center">
    <div class="flex items-center space-x-2">
      <% if generation.image.attached? %>
      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
        </svg>
        Image
      </span>
      <% end %>
      <% if generation.images.attached? %>
      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
        </svg>
        Gallery
      </span>
      <% end %>
    </div>
    <div class="flex space-x-2">
      <%= link_to "View", recipes_generation_path(generation), class: "text-sm font-medium text-emerald-700 hover:text-emerald-600" %>
      <% if Current.user&.admin? || generation.user == Current.user %>
      <%= link_to "Edit", edit_recipes_generation_path(generation), class: "text-sm font-medium text-slate-600 hover:text-slate-800" %>
      <%= link_to "Delete", recipes_generation_path(generation), 
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this recipe generation? This cannot be undone." }, 
                  class: "text-red-600 hover:text-red-800 text-sm font-medium" %>
      <% end %>
    </div>
  </div>
</div> 
