<div class="w-full">
  <% if notice.present? %>
  <p class="mb-5 inline-block rounded-2xl border border-emerald-200 bg-emerald-50 px-3 py-2 font-medium text-emerald-800" id="notice"><%= notice %></p>
  <% end %>

  <% content_for :title, "Recipe Generations" %>

  <div class="mx-auto max-w-7xl overflow-hidden sm:px-6 lg:px-8">
    <h1 class="text-center text-3xl font-semibold text-slate-900">Recipe Generations</h1>
    <div class="mx-auto w-full sm:w-2/3 my-4">
      <%= render 'shared/search', label: "Search Generations", placeholder: "Pasta recipe", path: recipes_generations_path %>
      <p class="mt-2 text-center text-slate-500">
        <%= link_to 'Generate a new recipe', new_recipes_generation_path, class: "stovaro-link text-xs underline" %>
      </p>
    </div>

    <div class="mx-auto mb-6 max-w-3xl rounded-3xl bg-stone-100 p-5">
      <p class="text-sm font-medium text-slate-900"><%= generation_allowance_summary(Current.user) %></p>
      <% unless Current.user.pro? %>
        <p class="mt-2 text-sm text-slate-600"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> includes 15 AI recipe generations per month. <%= link_to "See pricing", pricing_path, class: "font-semibold underline" %>.</p>
      <% end %>
    </div>

    <% unless Current.user.pro? %>
      <div class="mx-auto mb-8 max-w-5xl rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Extra generations</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900">Credit packs for bulk recipe creation</h2>
          </div>
          <%= link_to "See all pricing", pricing_path, class: "stovaro-btn-secondary" %>
        </div>

        <div class="mt-5">
          <%= render "credit_packs", credit_packs: @credit_packs %>
        </div>
      </div>
    <% end %>

    <% if @generations.blank? %>
    <div class="text-center mt-8 mb-12">
      <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-slate-900">No generations found</h3>
      <p class="mt-1 text-sm text-slate-500">Get started by generating a new recipe with AI or try a different search.</p>
      <%= link_to 'Generate New Recipe', new_recipes_generation_path, class: "stovaro-btn-primary mt-6" %>
    </div>
    <% else %>
    <div id="generations" class="my-6 space-y-6">
      <% @generations.each do |generation| %>
      <%= render "card", generation: generation %>
      <% end %>
    </div>
    <%== pagy_nav_custom(@pagy) %>
    <% end %>
  </div>
</div> 
