<div class="w-full">
  <% content_for :title, "Edit Recipe Generation" %>

  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
    <div class="stovaro-surface overflow-hidden">
      <div class="border-b border-stone-200 px-6 py-4">
        <h1 class="text-2xl font-bold text-slate-900">Edit Recipe Generation</h1>
        <p class="mt-1 text-sm text-slate-600">
          Modify the prompt for this recipe generation.
        </p>
      </div>

      <div class="px-6 py-6">
        <%= render 'form', generation: @generation %>
      </div>

      <div class="border-t border-stone-200 bg-stone-100 px-6 py-4">
        <div class="flex justify-between">
          <%= link_to "Back to Generation", recipes_generation_path(@generation), class: "stovaro-btn-secondary px-3 py-2" %>
          <%= link_to "Delete Generation", recipes_generation_path(@generation), method: :delete, 
                      data: { confirm: "Are you sure? This will delete the generation and all its data." }, 
                      class: "inline-flex items-center rounded-xl bg-red-600 px-3 py-2 text-sm font-medium leading-4 text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        </div>
      </div>
    </div>
  </div>
</div> 
