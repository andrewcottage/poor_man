<div class="w-full">
  <% content_for :title, "Generate New Recipe" %>

  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
    <div class="stovaro-surface overflow-hidden">
      <div class="border-b border-stone-200 px-6 py-4">
        <h1 class="text-2xl font-bold text-slate-900">Generate New Recipe</h1>
        <p class="mt-1 text-sm text-slate-600">
          Describe what kind of recipe you'd like to generate and AI will create it for you.
        </p>
      </div>

      <div class="px-6 py-6">
        <div class="mb-6 rounded-2xl bg-stone-100 p-4 text-sm text-slate-700">
          <p class="font-medium text-slate-900"><%= generation_allowance_summary(Current.user) %></p>
          <% unless Current.user.pro? %>
            <p class="mt-2"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> unlocks 15 AI generations each month. <%= link_to "See pricing", pricing_path, class: "font-semibold underline" %>.</p>
          <% end %>
        </div>

        <%= render 'form', generation: @generation %>

        <% unless Current.user.pro? %>
          <div class="mt-8 rounded-3xl border border-stone-200 bg-stone-100 p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Need more generations?</p>
                <h2 class="mt-2 text-xl font-semibold text-slate-900">Buy a credit pack or upgrade to <%= Billing::PlanCatalog::PRO_DISPLAY_NAME %></h2>
              </div>
              <%= link_to "Pricing", pricing_path, class: "stovaro-btn-secondary" %>
            </div>

            <div class="mt-5">
              <%= render "credit_packs", credit_packs: @credit_packs %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="border-t border-stone-200 bg-stone-100 px-6 py-4">
        <div class="flex justify-between">
          <%= link_to "Back to Generations", recipes_generations_path, class: "stovaro-btn-secondary px-3 py-2" %>
        </div>
      </div>
    </div>
  </div>
</div> 
