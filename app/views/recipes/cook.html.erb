<div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8" data-controller="cook-mode">
  <div class="rounded-[2rem] bg-slate-950 px-8 py-8 text-white shadow-xl">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.25em] text-emerald-300">Cook Mode</p>
        <h1 class="mt-2 text-3xl font-semibold"><%= @recipe.title %></h1>
        <p class="mt-3 text-sm text-slate-200"><%= pluralize(@selected_servings, "serving") %> • distraction-free step mode</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <%= link_to "Back to recipe", recipe_path(@recipe.slug, servings: @selected_servings), class: "rounded-xl border border-white/20 px-4 py-3 text-sm font-semibold text-white hover:bg-white/10" %>
        <%= link_to "Print view", print_recipe_path(@recipe.slug, servings: @selected_servings), class: "rounded-xl bg-emerald-300 px-4 py-3 text-sm font-semibold text-slate-950 hover:bg-emerald-200" %>
      </div>
    </div>
  </div>

  <div class="mt-8 grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <aside class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-semibold text-slate-900">Ingredients</h2>
      <ul class="mt-4 space-y-3 text-base text-slate-700">
        <% @scaled_ingredients.each do |ingredient| %>
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 rounded-full bg-slate-300"></span>
            <span><%= ingredient.display_text %></span>
          </li>
        <% end %>
      </ul>
    </aside>

    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Step</p>
          <h2 class="mt-2 text-2xl font-semibold text-slate-900" data-cook-mode-target="counter">1 / <%= @instruction_steps.size %></h2>
        </div>
        <div class="rounded-2xl bg-slate-100 px-4 py-3 text-sm text-slate-600" data-cook-mode-target="timer">No timer set</div>
      </div>

      <div class="mt-6 space-y-5">
        <% @instruction_steps.each_with_index do |step, index| %>
          <article class="<%= index.zero? ? '' : 'hidden' %> rounded-3xl bg-slate-50 p-6" data-cook-mode-target="step" data-timer-minutes="<%= step[/(\d+)\s*(minutes?|minute|min)/i, 1] %>">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Step <%= index + 1 %></p>
            <p class="mt-4 text-2xl leading-relaxed text-slate-900"><%= step %></p>
          </article>
        <% end %>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <button type="button" data-action="cook-mode#previous" class="rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Previous</button>
        <button type="button" data-action="cook-mode#next" class="rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white hover:bg-slate-800">Next</button>
        <button type="button" data-action="cook-mode#startTimer" class="rounded-xl border border-emerald-300 px-4 py-3 text-sm font-semibold text-emerald-700 hover:bg-emerald-50">Start step timer</button>
      </div>
    </section>
  </div>
</div>
