<div class="w-full">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 py-8 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-gray-500">
          <%= link_to @family.name, family_path(@family), class: "hover:text-gray-700" %> / Cookbook
        </p>
        <h1 class="mt-2 text-3xl font-semibold text-gray-900"><%= @cookbook.name %></h1>
        <% if @cookbook.description.present? %>
          <p class="mt-3 max-w-2xl text-sm text-gray-600"><%= @cookbook.description %></p>
        <% end %>
      </div>

      <div class="flex gap-3">
        <%= link_to "Edit", edit_family_cookbook_path(@family, @cookbook), class: "rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
        <%= button_to "Delete", family_cookbook_path(@family, @cookbook), method: :delete, data: { turbo_confirm: "Delete this cookbook?" }, class: "rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100" %>
      </div>
    </div>

    <%# Add recipe form %>
    <div class="mb-6">
      <%= form_with url: family_cookbook_recipes_path(@family, @cookbook), method: :post, class: "flex gap-3 items-end" do |form| %>
        <div class="flex-1">
          <%= form.label :recipe_id, "Add a recipe by ID", class: "block text-sm font-medium text-gray-700" %>
          <%= form.number_field :recipe_id, placeholder: "Recipe ID", class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
        </div>
        <%= form.submit "Add recipe", class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800 cursor-pointer" %>
      <% end %>
    </div>

    <% if @cookbook.family_cookbook_recipes.blank? %>
      <div class="rounded-[2rem] border border-dashed border-gray-300 px-6 py-12 text-center">
        <h2 class="text-lg font-semibold text-gray-900">No recipes in this cookbook yet</h2>
        <p class="mt-2 text-sm text-gray-600">Add recipes from any approved recipe page, or use the form above.</p>
      </div>
    <% else %>
      <div class="grid gap-4 pb-12 md:grid-cols-2 xl:grid-cols-3">
        <% @cookbook.family_cookbook_recipes.includes(recipe: [:category]).each do |cookbook_recipe| %>
          <% recipe = cookbook_recipe.recipe %>
          <article class="overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-sm">
            <%= image_tag(recipe.image, class: "aspect-[4/3] w-full object-cover") if recipe.image.attached? %>
            <div class="space-y-4 p-5">
              <div>
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500"><%= recipe.category.title %></p>
                <h2 class="mt-2 text-xl font-semibold text-gray-900">
                  <%= link_to recipe.title, recipe_path(recipe.slug), class: "hover:text-gray-600" %>
                </h2>
              </div>
              <p class="text-sm text-gray-600"><%= recipe.blurb %></p>
              <div class="flex items-center justify-between">
                <p class="text-xs text-gray-400">Added by <%= cookbook_recipe.contributor.username %></p>
                <%= button_to "Remove", family_cookbook_recipe_path(@family, @cookbook, cookbook_recipe), method: :delete, class: "rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
