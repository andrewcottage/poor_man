<div class="w-full">
  <div class="mx-auto max-w-2xl px-4 py-8 sm:px-6 lg:px-8">
    <p class="text-sm uppercase tracking-[0.2em] text-gray-500">
      <%= link_to @family.name, family_path(@family), class: "hover:text-gray-700" %> / Edit Cookbook
    </p>
    <h1 class="mt-2 text-3xl font-semibold text-gray-900">Edit <%= @cookbook.name %></h1>

    <div class="mt-6">
      <%= form_with model: @cookbook, url: family_cookbook_path(@family, @cookbook), method: :patch, class: "space-y-4" do |form| %>
        <% if @cookbook.errors.any? %>
          <div class="rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-700">
            <%= @cookbook.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div>
          <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field :name, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
        </div>

        <div>
          <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :description, rows: 3, class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
        </div>

        <div class="flex gap-3">
          <%= form.submit "Save", class: "inline-flex justify-center rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white hover:bg-gray-800 cursor-pointer" %>
          <%= link_to "Cancel", family_cookbook_path(@family, @cookbook), class: "inline-flex justify-center rounded-xl border border-gray-300 px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
