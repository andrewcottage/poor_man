<div class="w-full">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Family</p>
        <h1 class="mt-2 text-3xl font-semibold text-gray-900"><%= @family.name %></h1>
        <p class="mt-1 text-sm text-gray-600"><%= pluralize(@family.members.count, "member") %></p>
      </div>

      <% if @family.admin_or_owner?(Current.user) %>
        <div class="flex gap-3">
          <%= link_to "Edit", edit_family_path(@family), class: "rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
          <%= button_to "Delete", family_path(@family), method: :delete, data: { turbo_confirm: "Delete this family and all its cookbooks?" }, class: "rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100" %>
        </div>
      <% end %>
    </div>

    <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_0.6fr]">
      <%# Cookbooks section %>
      <section>
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold text-gray-900">Cookbooks</h2>
        </div>

        <div class="mt-4">
          <%= form_with model: FamilyCookbook.new, url: family_cookbooks_path(@family), class: "flex gap-3" do |form| %>
            <%= form.text_field :name, placeholder: "New cookbook name", class: "flex-1 rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
            <%= form.submit "Create", class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800 cursor-pointer" %>
          <% end %>
        </div>

        <% if @cookbooks.blank? %>
          <div class="mt-4 rounded-[2rem] border border-dashed border-gray-300 px-6 py-12 text-center">
            <h3 class="text-lg font-semibold text-gray-900">No cookbooks yet</h3>
            <p class="mt-2 text-sm text-gray-600">Create a cookbook to start collecting family recipes.</p>
          </div>
        <% else %>
          <div class="mt-4 grid gap-4 md:grid-cols-2">
            <% @cookbooks.each do |cookbook| %>
              <article class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
                <p class="text-sm uppercase tracking-[0.2em] text-gray-500"><%= pluralize(cookbook.recipes.count, "recipe") %></p>
                <h3 class="mt-3 text-xl font-semibold text-gray-900">
                  <%= link_to cookbook.name, family_cookbook_path(@family, cookbook), class: "hover:text-gray-600" %>
                </h3>
                <% if cookbook.description.present? %>
                  <p class="mt-2 text-sm text-gray-600"><%= cookbook.description %></p>
                <% end %>
                <div class="mt-4">
                  <%= link_to "Open", family_cookbook_path(@family, cookbook), class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800" %>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>
      </section>

      <%# Members section %>
      <section>
        <h2 class="text-xl font-semibold text-gray-900">Members</h2>

        <% if @family.admin_or_owner?(Current.user) %>
          <div class="mt-4">
            <%= form_with url: family_memberships_path(@family), method: :post, class: "flex gap-3" do |form| %>
              <%= form.email_field :email, placeholder: "Add member by email", class: "flex-1 rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
              <%= form.submit "Add", class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800 cursor-pointer" %>
            <% end %>
          </div>
        <% end %>

        <div class="mt-4 space-y-3">
          <% @family.family_memberships.includes(:user).order(role: :desc).each do |membership| %>
            <div class="flex items-center justify-between rounded-2xl border border-gray-200 bg-white px-4 py-3 shadow-sm">
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-gray-900"><%= membership.user.name || membership.user.username %></p>
                <p class="truncate text-xs text-gray-500"><%= membership.user.email %></p>
              </div>
              <div class="flex items-center gap-2">
                <span class="rounded-full px-2.5 py-0.5 text-xs font-medium
                  <%= case membership.role
                      when 'owner' then 'bg-amber-100 text-amber-800'
                      when 'admin' then 'bg-blue-100 text-blue-800'
                      else 'bg-gray-100 text-gray-700'
                      end %>">
                  <%= membership.role.capitalize %>
                </span>

                <% if @family.admin_or_owner?(Current.user) && !membership.owner? %>
                  <% if membership.member? %>
                    <%= button_to "Make admin", family_membership_path(@family, membership), method: :patch, params: { role: :admin }, class: "text-xs text-blue-600 hover:underline" %>
                  <% elsif membership.admin? %>
                    <%= button_to "Make member", family_membership_path(@family, membership), method: :patch, params: { role: :member }, class: "text-xs text-gray-600 hover:underline" %>
                  <% end %>
                  <%= button_to "Remove", family_membership_path(@family, membership), method: :delete, data: { turbo_confirm: "Remove this member?" }, class: "text-xs text-red-600 hover:underline" %>
                <% elsif membership.user == Current.user && !membership.owner? %>
                  <%= button_to "Leave", family_membership_path(@family, membership), method: :delete, data: { turbo_confirm: "Leave this family?" }, class: "text-xs text-red-600 hover:underline" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>
