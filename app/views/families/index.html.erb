<div class="w-full">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 py-8 lg:grid-cols-[0.75fr_1.25fr]">
      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Families</p>
        <h1 class="mt-3 text-3xl font-semibold text-gray-900">Your families</h1>
        <p class="mt-3 text-sm text-gray-600">Create a family to share cookbooks and recipes with the people you cook with.</p>

        <div class="mt-6">
          <%= form_with model: @family, url: families_path, class: "space-y-4" do |form| %>
            <% if @family.errors.any? %>
              <div class="rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-700">
                <%= @family.errors.full_messages.to_sentence %>
              </div>
            <% end %>

            <div>
              <%= form.label :name, "Family name", class: "block text-sm font-medium text-gray-700" %>
              <%= form.text_field :name, placeholder: "e.g. The Cottages", class: "mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900" %>
            </div>

            <%= form.submit "Create family", class: "inline-flex justify-center rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white hover:bg-gray-800 cursor-pointer" %>
          <% end %>
        </div>
      </section>

      <section>
        <% if @families.blank? %>
          <div class="rounded-[2rem] border border-dashed border-gray-300 px-6 py-12 text-center">
            <h2 class="text-lg font-semibold text-gray-900">No families yet</h2>
            <p class="mt-2 text-sm text-gray-600">Create your first family to start sharing recipes together.</p>
          </div>
        <% else %>
          <div class="grid gap-4 md:grid-cols-2">
            <% @families.each do |family| %>
              <article class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
                <p class="text-sm uppercase tracking-[0.2em] text-gray-500"><%= pluralize(family.members.count, "member") %></p>
                <h2 class="mt-3 text-2xl font-semibold text-gray-900">
                  <%= link_to family.name, family_path(family), class: "hover:text-gray-600" %>
                </h2>
                <p class="mt-1 text-sm text-gray-600"><%= pluralize(family.family_cookbooks.count, "cookbook") %></p>
                <div class="mt-6 flex gap-3">
                  <%= link_to "Open", family_path(family), class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800" %>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>
