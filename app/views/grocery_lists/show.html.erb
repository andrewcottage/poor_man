<div class="mx-auto mt-10 max-w-4xl space-y-8 px-4 sm:px-6 lg:px-8">
  <div class="rounded-3xl bg-slate-950 px-8 py-8 text-white shadow-xl">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-emerald-300">Shared Grocery List</p>
    <h1 class="mt-2 text-3xl font-semibold"><%= @grocery_list.title %></h1>
    <p class="mt-3 text-sm text-slate-200">Built from <%= @grocery_list.meal_plan.title %> on Stovaro.</p>
  </div>

  <div class="space-y-6">
    <% @grocery_list.grouped_items.each do |aisle, items| %>
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900"><%= aisle %></h2>
        <div class="mt-4 space-y-3">
          <% items.each do |item| %>
            <div class="rounded-2xl bg-slate-50 px-4 py-3">
              <p class="text-base font-medium text-slate-900 <%= "line-through text-slate-400" if item.checked? %>"><%= item.display_text %></p>
              <% if item.notes.present? %>
                <p class="mt-1 text-sm text-slate-500"><%= item.notes %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
