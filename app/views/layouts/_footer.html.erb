<div class="mx-auto mt-16 max-w-7xl px-6 lg:px-8">
  <footer aria-labelledby="footer-heading" class="relative overflow-hidden rounded-[2.5rem] bg-slate-950 px-6 py-10 text-white shadow-xl sm:px-8 lg:px-10">
    <div class="pointer-events-none absolute -left-8 top-0 h-28 w-28 rounded-full bg-amber-300/20 blur-3xl"></div>
    <div class="pointer-events-none absolute right-0 top-10 h-36 w-36 rounded-full bg-emerald-300/20 blur-3xl"></div>
    <h2 id="footer-heading" class="sr-only">Footer</h2>

    <div class="relative grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <div>
        <%= link_to root_path, class: "inline-flex items-center gap-4" do %>
          <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white shadow-sm">
            <%= image_tag "logo.svg", class: "h-10 w-10 rounded-xl object-contain", alt: "Stovaro" %>
          </span>
          <span>
            <span class="block text-sm font-semibold uppercase tracking-[0.35em] text-amber-300">Stovaro</span>
            <span class="mt-1 block text-sm text-slate-300">Plan dinner, keep groceries organized, and cook without switching tools.</span>
          </span>
        <% end %>

        <p class="mt-6 max-w-xl text-base leading-7 text-slate-200">
          Built for everyday home cooks who want one place for recipes, AI generation, meal planning, and grocery follow-through.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Browse recipes", recipes_path, class: "stovaro-btn-secondary px-4 py-2" %>
          <%= link_to "See pricing", pricing_path, class: "stovaro-btn-accent px-4 py-2" %>
        </div>
      </div>

      <div class="grid gap-8 sm:grid-cols-3">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-300">Explore</h3>
          <ul role="list" class="mt-5 space-y-3">
            <li><%= link_to "Recipes", recipes_path, class: "text-sm text-slate-200 transition hover:text-white" %></li>
            <li><%= link_to "Categories", categories_path, class: "text-sm text-slate-200 transition hover:text-white" %></li>
            <li><%= link_to "Pricing", pricing_path, class: "text-sm text-slate-200 transition hover:text-white" %></li>
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-300">Company</h3>
          <ul role="list" class="mt-5 space-y-3">
            <li><%= link_to "About", about_pages_path, class: "text-sm text-slate-200 transition hover:text-white" %></li>
            <li><%= link_to "Privacy", privacy_pages_path, class: "text-sm text-slate-200 transition hover:text-white" %></li>
            <li><%= link_to "Terms", terms_pages_path, class: "text-sm text-slate-200 transition hover:text-white" %></li>
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-300">Connect</h3>
          <ul role="list" class="mt-5 space-y-3">
            <li><a href="mailto:support@stovaro.com" class="text-sm text-slate-200 transition hover:text-white">support@stovaro.com</a></li>
            <li><a href="https://github.com/andrewhwanpark" class="text-sm text-slate-200 transition hover:text-white">GitHub</a></li>
            <li><a href="https://commerce.coinbase.com/checkout/8c355aea-4058-4360-8398-898f9b45b49f" class="text-sm text-slate-200 transition hover:text-white">Donate</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="relative mt-10 border-t border-white/10 pt-6 sm:flex sm:items-center sm:justify-between">
      <p class="text-xs leading-5 text-slate-400">&copy; <%= Date.current.year %> Stovaro. All rights reserved.</p>
      <p class="mt-3 text-xs uppercase tracking-[0.25em] text-slate-500 sm:mt-0">Recipes. Planning. Grocery follow-through.</p>
    </div>
  </footer>
</div>
