<aside class="relative flex h-full min-h-[24rem] flex-col overflow-hidden rounded-[2rem] bg-slate-950 text-slate-100 shadow-[0_28px_90px_rgba(15,23,42,0.32)] ring-1 ring-slate-900/70">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-[radial-gradient(circle_at_top,_rgba(251,191,36,0.24),_transparent_60%)]"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-px bg-white/10"></div>

  <div class="relative border-b border-white/10 px-4 pb-4 pt-5 sm:px-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <p class="text-[11px] font-semibold uppercase tracking-[0.28em] text-slate-400">Chats</p>
        <h2 class="mt-2 text-lg font-semibold text-white">Recent conversations</h2>
        <p class="mt-1 text-xs leading-5 text-slate-400">Keep separate recipe, planning, and seed threads with their own context.</p>
      </div>
    </div>

    <%= button_to create_conversation_chat_path,
        method: :post,
        class: "mt-4 inline-flex w-full items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/8 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:border-white/15 hover:bg-white/12" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14" />
      </svg>
      New chat
    <% end %>
  </div>

  <div class="relative flex-1 overflow-y-auto px-3 pb-4 pt-3 sm:px-4">
    <div class="space-y-2.5">
      <% conversations.each do |conversation| %>
        <% active = conversation == current_conversation %>
        <div class="group rounded-[1.35rem] transition">
          <%= link_to chat_conversation_path(conversation),
              class: [
                "block rounded-[1.35rem] px-3.5 py-3.5 transition",
                active ? "bg-white/12 shadow-[inset_0_1px_0_rgba(255,255,255,0.08)] ring-1 ring-white/10" : "hover:bg-white/6"
              ].join(" ") do %>
            <div class="flex items-start gap-3">
              <div class="<%= active ? 'bg-amber-400/16 text-amber-200 ring-1 ring-amber-300/20' : 'bg-white/6 text-slate-300 ring-1 ring-white/6' %> mt-0.5 flex h-9 w-9 flex-none items-center justify-center rounded-2xl">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a3.375 3.375 0 116.75 0c0 1.365-.808 2.541-1.97 3.074-.598.275-1.03.83-1.03 1.489V15m0 3h.008v.008H12v-.008z" />
                </svg>
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-3">
                  <p class="<%= active ? 'text-white' : 'text-slate-100' %> truncate text-sm font-semibold leading-5"><%= conversation.display_title %></p>
                  <span class="mt-0.5 flex-none text-[11px] font-medium uppercase tracking-[0.18em] <%= active ? 'text-amber-200/80' : 'text-slate-500' %>">
                    <%= conversation_timestamp_label(conversation) %>
                  </span>
                </div>
                <p class="mt-1.5 line-clamp-2 text-xs leading-5 <%= active ? 'text-slate-200/80' : 'text-slate-400' %>">
                  <%= conversation.preview_text.presence || "No messages yet. Start with a prompt to give this thread its own context." %>
                </p>
              </div>
            </div>
          <% end %>

          <% if active %>
            <div class="mt-2 rounded-[1.15rem] border border-white/10 bg-black/20 p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.03)]">
              <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-400">Manage current chat</p>
              <div class="flex flex-col gap-2">
                <%= form_with url: update_chat_conversation_path(conversation), method: :patch, class: "flex items-center gap-2" do %>
                  <%= text_field_tag :title,
                      conversation.display_title,
                      class: "h-10 flex-1 rounded-xl border border-white/10 bg-white/6 px-3 text-sm text-white placeholder:text-slate-500 focus:border-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-300/20" %>
                  <%= submit_tag "Rename", class: "inline-flex h-10 items-center rounded-xl bg-white px-3.5 text-sm font-semibold text-slate-900 transition hover:bg-amber-100" %>
                <% end %>

                <%= button_to destroy_chat_conversation_path(conversation),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this chat?" } },
                    class: "inline-flex h-10 items-center justify-center rounded-xl border border-red-400/20 bg-red-500/8 px-3.5 text-sm font-semibold text-red-200 transition hover:bg-red-500/14" do %>
                  Delete chat
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</aside>
