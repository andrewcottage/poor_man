<div class="mx-auto mt-10 max-w-7xl space-y-8 px-4 sm:px-6 lg:px-8">
  <div class="overflow-hidden rounded-3xl bg-slate-950 px-8 py-8 text-white shadow-xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-emerald-300"><%= Billing::PlanCatalog::PRO_DISPLAY_NAME %> Planner</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl"><%= @meal_plan.title %></h1>
        <p class="mt-3 max-w-2xl text-sm text-slate-200 sm:text-base">Assign recipes to your week, keep dinner decisions off your plate, and turn the plan into a reusable grocery list.</p>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= link_to "Previous week", profiles_meal_plan_path(week_of: @meal_plan.week_of - 7.days), class: "rounded-xl border border-white/20 px-4 py-3 text-sm font-semibold text-white hover:bg-white/10" %>
        <%= link_to "Next week", profiles_meal_plan_path(week_of: @meal_plan.week_of + 7.days), class: "rounded-xl border border-white/20 px-4 py-3 text-sm font-semibold text-white hover:bg-white/10" %>
        <%= button_to "Generate grocery list", profiles_grocery_lists_path(week_of: @meal_plan.week_of), method: :post, class: "rounded-xl bg-emerald-300 px-4 py-3 text-sm font-semibold text-slate-950 hover:bg-emerald-200" %>
      </div>
    </div>
  </div>

  <div class="grid gap-8 xl:grid-cols-[minmax(0,2fr),22rem]">
    <div class="space-y-6">
      <div class="grid gap-4 lg:grid-cols-2 2xl:grid-cols-4">
        <% @meal_plan.days.each do |day| %>
          <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="mb-4">
              <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500"><%= day.strftime("%A") %></p>
              <h2 class="mt-1 text-lg font-semibold text-slate-900"><%= l(day, format: :long) %></h2>
            </div>

            <div class="space-y-3">
              <% day_meals = @meal_plan.planned_meals_for(day) %>
              <% if day_meals.any? %>
                <% day_meals.each do |planned_meal| %>
                  <article class="rounded-2xl bg-slate-50 p-4">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= planned_meal.meal_type.humanize %></p>
                        <h3 class="mt-1 text-base font-semibold text-slate-900"><%= link_to planned_meal.recipe.title, recipe_path(planned_meal.recipe.slug), class: "hover:text-slate-600" %></h3>
                      </div>
                      <div class="flex items-center gap-2">
                        <%= button_to "Copy", duplicate_profiles_planned_meal_path(planned_meal), method: :post, class: "rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-white" %>
                        <%= button_to "Remove", profiles_planned_meal_path(planned_meal), method: :delete, class: "rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-700 hover:bg-rose-50" %>
                      </div>
                    </div>

                    <div class="mt-3 rounded-xl border border-slate-200 bg-white p-3">
                      <%= form_with model: [ :profiles, planned_meal ], class: "space-y-3" do |form| %>
                        <div>
                          <%= form.label :scheduled_on, "Move to", class: "text-xs font-semibold uppercase tracking-[0.2em] text-slate-500" %>
                          <%= form.date_field :scheduled_on, value: planned_meal.scheduled_on, min: @meal_plan.week_of, max: @meal_plan.week_of + 6.days, class: "mt-1 block w-full rounded-xl border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
                        </div>
                        <div>
                          <%= form.label :meal_type, class: "text-xs font-semibold uppercase tracking-[0.2em] text-slate-500" %>
                          <%= form.select :meal_type, meal_type_options(planned_meal.meal_type), {}, class: "mt-1 block w-full rounded-xl border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
                        </div>
                        <%= form.submit "Update slot", class: "w-full rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" %>
                      <% end %>
                    </div>
                  </article>
                <% end %>
              <% else %>
                <p class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-sm text-slate-500">No meals planned yet.</p>
              <% end %>
            </div>

            <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Add a meal</p>
              <%= form_with url: profiles_planned_meals_path, scope: :planned_meal, class: "mt-3 space-y-3" do |form| %>
                <%= form.hidden_field :scheduled_on, value: day %>
                <div>
                  <%= form.label :meal_type, class: "text-xs font-semibold uppercase tracking-[0.2em] text-slate-500" %>
                  <%= form.select :meal_type, meal_type_options("dinner"), {}, class: "mt-1 block w-full rounded-xl border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
                </div>
                <div>
                  <%= form.label :recipe_id, "Recipe", class: "text-xs font-semibold uppercase tracking-[0.2em] text-slate-500" %>
                  <%= form.select :recipe_id, grouped_options_for_select(@planner_recipe_groups), { prompt: "Choose a recipe" }, class: "mt-1 block w-full rounded-xl border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
                </div>
                <%= form.submit "Add to plan", class: "w-full rounded-xl bg-emerald-400 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-emerald-300" %>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    </div>

    <aside class="space-y-6">
      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Suggested inputs</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">Plan from favorites and recent recipes</h2>
        <p class="mt-3 text-sm text-slate-600">The add-meal forms prioritize your favorites and the newest approved recipes so you can fill a week quickly without hunting through the full recipe library.</p>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Grocery sync</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900">Current grocery list</h2>
          </div>
          <% if @grocery_list.present? %>
            <%= link_to "Open list", profiles_grocery_list_path(@grocery_list), class: "rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
          <% end %>
        </div>

        <% if @grocery_list.present? %>
          <p class="mt-3 text-sm text-slate-600">Last generated <%= time_ago_in_words(@grocery_list.generated_at || @grocery_list.updated_at) %> ago.</p>
          <div class="mt-4 space-y-3">
            <% @grocery_list.grocery_list_items.limit(6).each do |item| %>
              <div class="rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-700">
                <span class="<%= item.checked? ? "line-through text-slate-400" : "" %>"><%= item.display_text %></span>
                <% if item.notes.present? %>
                  <p class="mt-1 text-xs text-slate-500"><%= item.notes %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 text-sm text-slate-600">Generate the list once you have recipes assigned. It will combine repeated ingredients and keep the list around for shopping.</p>
        <% end %>
      </section>
    </aside>
  </div>
</div>
