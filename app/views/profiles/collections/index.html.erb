<div class="w-full">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 py-8 lg:grid-cols-[0.75fr_1.25fr]">
      <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
        <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Cookbooks</p>
        <h1 class="mt-3 text-3xl font-semibold text-gray-900">Your collections</h1>
        <p class="mt-3 text-sm text-gray-600">Organize saved recipes into weeknight dinners, party food, vegan staples, or whatever matches how you cook.</p>

        <% if Current.user.free? && !Current.user.can_create_collection? %>
          <div class="mt-6 rounded-2xl bg-amber-50 px-4 py-4 text-sm text-amber-800">
            Free accounts can create 1 collection. <%= link_to "Upgrade to #{Billing::PlanCatalog::PRO_DISPLAY_NAME}", pricing_path, class: "font-semibold underline" %> for unlimited cookbooks.
          </div>
        <% end %>

        <div class="mt-6">
          <%= render "form", collection: @collection %>
        </div>
      </section>

      <section>
        <% if @collections.blank? %>
          <div class="rounded-[2rem] border border-dashed border-gray-300 px-6 py-12 text-center">
            <h2 class="text-lg font-semibold text-gray-900">No collections yet</h2>
            <p class="mt-2 text-sm text-gray-600">Create your first cookbook to start organizing favorites.</p>
          </div>
        <% else %>
          <div class="grid gap-4 md:grid-cols-2">
            <% @collections.each do |collection| %>
              <article class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
                <p class="text-sm uppercase tracking-[0.2em] text-gray-500"><%= pluralize(collection.recipes.count, "recipe") %></p>
                <h2 class="mt-3 text-2xl font-semibold text-gray-900">
                  <%= link_to collection.name, profiles_collection_path(collection), class: "hover:text-gray-600" %>
                </h2>
                <% if collection.description.present? %>
                  <p class="mt-3 text-sm text-gray-600"><%= collection.description %></p>
                <% end %>
                <div class="mt-6 flex gap-3">
                  <%= link_to "Open", profiles_collection_path(collection), class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800" %>
                  <%= link_to "Edit", edit_profiles_collection_path(collection), class: "rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>
      </section>
    </div>
  </div>
</div>
