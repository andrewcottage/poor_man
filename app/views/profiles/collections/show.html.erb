<div class="w-full">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 py-8 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-gray-500">Collection</p>
        <h1 class="mt-2 text-3xl font-semibold text-gray-900"><%= @collection.name %></h1>
        <% if @collection.description.present? %>
          <p class="mt-3 max-w-2xl text-sm text-gray-600"><%= @collection.description %></p>
        <% end %>
      </div>

      <div class="flex gap-3">
        <%= link_to "Edit", edit_profiles_collection_path(@collection), class: "rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
        <%= button_to "Delete", profiles_collection_path(@collection), method: :delete, data: { turbo_confirm: "Delete this collection?" }, class: "rounded-xl bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100" %>
      </div>
    </div>

    <% if @collection.collection_recipes.blank? %>
      <div class="rounded-[2rem] border border-dashed border-gray-300 px-6 py-12 text-center">
        <h2 class="text-lg font-semibold text-gray-900">No recipes in this collection yet</h2>
        <p class="mt-2 text-sm text-gray-600">Add recipes from any approved recipe page.</p>
      </div>
    <% else %>
      <div class="grid gap-4 pb-12 md:grid-cols-2 xl:grid-cols-3">
        <% @collection.collection_recipes.includes(:recipe).each do |collection_recipe| %>
          <% recipe = collection_recipe.recipe %>
          <article class="overflow-hidden rounded-[2rem] border border-gray-200 bg-white shadow-sm">
            <%= image_tag(recipe.image, class: "aspect-[4/3] w-full object-cover") if recipe.image.attached? %>
            <div class="space-y-4 p-5">
              <div>
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500"><%= recipe.category.title %></p>
                <h2 class="mt-2 text-xl font-semibold text-gray-900">
                  <%= link_to recipe.title, recipe_path(recipe.slug), class: "hover:text-gray-600" %>
                </h2>
              </div>
              <p class="text-sm text-gray-600"><%= recipe.blurb %></p>
              <%= button_to "Remove", profiles_collection_recipe_path(collection_recipe), method: :delete, class: "rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100" %>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
